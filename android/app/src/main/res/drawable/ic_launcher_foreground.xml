<?xml version="1.0" encoding="utf-8"?>
<!--
    FlowBoard app icon foreground — Bold "F" lettermark
    Inspired by Figma / Linear style: thick geometric letter with rounded ends
    + bright accent dot representing "flow" at the crossbar tip
    Canvas: 108×108dp  |  Safe zone: 72×72dp centered (from 18,18 to 90,90)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Vertical stroke of F ── -->
    <!-- rect: (26,23)→(42,85), r=5 -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M31,23 H37 Q42,23 42,28 V80 Q42,85 37,85 H31 Q26,85 26,80 V28 Q26,23 31,23 Z"/>

    <!-- ── Top horizontal bar of F (full width) ── -->
    <!-- rect: (26,23)→(80,38), r=5 -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M31,23 H75 Q80,23 80,28 V33 Q80,38 75,38 H31 Q26,38 26,33 V28 Q26,23 31,23 Z"/>

    <!-- ── Middle crossbar of F (shorter — classic F proportion) ── -->
    <!-- rect: (42,45)→(65,59), r=5  — starts at right edge of vertical stroke -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M47,45 H60 Q65,45 65,50 V54 Q65,59 60,59 H47 Q42,59 42,54 V50 Q42,45 47,45 Z"/>

    <!-- ── Accent dot — "flow" indicator, tangent to crossbar end ── -->
    <!-- circle: center (72,52), r=7  — touches crossbar at x=65 -->
    <path
        android:fillColor="#38BDF8"
        android:pathData="M65,52 A7,7 0 1,0 79,52 A7,7 0 1,0 65,52 Z"/>

</vector>
